  "target_code": "fn main() {\n    let mut input = String::new();\n    use std::io::{self, prelude::*};\n    io::stdin().read_to_string(&mut input).unwrap();\n\n    let mut it = input.split_whitespace();\n\n    let n: u32 = it.next().unwrap().parse().unwrap();\n    let s: u32 = it.next().unwrap().parse().unwrap();\n\n    let ans = (s - 1) / n + 1;\n\n    println!(\"{}\", ans);\n}\n"
