  "target_code": "use std::io::stdin;\n     \nfn get_input(input: &mut String) {\n    input.clear();\n    stdin().read_line(input).expect(\"error\");\n}\n \nfn main() {\n    let mut input = String::new();\n \n    get_input(&mut input);\n    let mut numbers = input.trim().split_whitespace();\n    let n = numbers.next().unwrap().parse::<u64>().unwrap();\n    let k = numbers.next().unwrap().parse::<u64>().unwrap();\n    let max_price = std::cmp::min(n, k-1);\n    let min_price = k - max_price;\n    if min_price >= max_price {\n        println!(\"0\");\n    } else {\n        let length = max_price - min_price;\n        println!(\"{}\", length / 2 + length % 2);\n    }\n}"
