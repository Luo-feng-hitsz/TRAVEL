  "hidden_unit_tests": "[{\"input\": \"++-+-\\r\\n+-+-+\\r\\n\", \"output\": [\"1\", \"1.000000000000\", \"1.000000000\", \"1.0\", \"1.00000000000\", \"1.0000000000\"]}, {\"input\": \"+-+-\\r\\n+-??\\r\\n\", \"output\": [\"0.5\", \"0.50000000000\", \"0.500000000\", \"0.500000000000\", \"0.5000000000\"]}, {\"input\": \"+++\\r\\n??-\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"++++++++++\\r\\n+++??++?++\\r\\n\", \"output\": [\"0.1250000000\", \"0.125\", \"0.12500000000\", \"0.125000000\", \"0.125000000000\"]}, {\"input\": \"--+++---+-\\r\\n??????????\\r\\n\", \"output\": [\"0.205078125\", \"0.20507812500\", \"0.205078125000\", \"0.2050781250\"]}, {\"input\": \"+--+++--+-\\r\\n??????????\\r\\n\", \"output\": [\"0.24609375\", \"0.2460937500\", \"0.246093750\", \"0.246093750000\", \"0.24609375000\"]}, {\"input\": \"+\\r\\n+\\r\\n\", \"output\": [\"1\", \"1.000000000000\", \"1.000000000\", \"1.0\", \"1.00000000000\", \"1.0000000000\"]}, {\"input\": \"-\\r\\n?\\r\\n\", \"output\": [\"0.5\", \"0.50000000000\", \"0.500000000\", \"0.500000000000\", \"0.5000000000\"]}, {\"input\": \"+\\r\\n-\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"-\\r\\n-\\r\\n\", \"output\": [\"1\", \"1.000000000000\", \"1.000000000\", \"1.0\", \"1.00000000000\", \"1.0000000000\"]}, {\"input\": \"-\\r\\n+\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"+\\r\\n?\\r\\n\", \"output\": [\"0.5\", \"0.50000000000\", \"0.500000000\", \"0.500000000000\", \"0.5000000000\"]}, {\"input\": \"++++++++++\\r\\n++++++++++\\r\\n\", \"output\": [\"1\", \"1.000000000000\", \"1.000000000\", \"1.0\", \"1.00000000000\", \"1.0000000000\"]}, {\"input\": \"++++++++++\\r\\n++++-+++++\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"----------\\r\\n++++++++++\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"++++++++++\\r\\n++++??++++\\r\\n\", \"output\": [\"0.25\", \"0.2500000000\", \"0.250000000000\", \"0.25000000000\", \"0.250000000\"]}, {\"input\": \"----------\\r\\n+++?++++-+\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"++++++++++\\r\\n++++++++?+\\r\\n\", \"output\": [\"0.5\", \"0.50000000000\", \"0.500000000\", \"0.500000000000\", \"0.5000000000\"]}, {\"input\": \"--++++--+\\r\\n?-+?-??+-\\r\\n\", \"output\": [\"0.25\", \"0.2500000000\", \"0.250000000000\", \"0.25000000000\", \"0.250000000\"]}, {\"input\": \"----------\\r\\n??????????\\r\\n\", \"output\": [\"0.000976562500\", \"0.00097656250\", \"0.000976562500000\", \"0.000976563\", \"9.765625E-4\", \"0.0009765625\"]}, {\"input\": \"+--++\\r\\n+--+-\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"-----++---\\r\\n????????+?\\r\\n\", \"output\": [\"0.0175781250000\", \"0.01757812500\", \"0.017578125000\", \"0.0175781250\", \"0.017578125\"]}, {\"input\": \"------+--+\\r\\n??????????\\r\\n\", \"output\": [\"0.043945313\", \"0.0439453125000\", \"0.043945312500\", \"0.0439453125\", \"0.04394531250\"]}, {\"input\": \"---++--\\r\\n???????\\r\\n\", \"output\": [\"0.1640625000\", \"0.16406250000\", \"0.1640625\", \"0.164062500\", \"0.164062500000\"]}, {\"input\": \"-----++\\r\\n???????\\r\\n\", \"output\": [\"0.1640625000\", \"0.16406250000\", \"0.1640625\", \"0.164062500\", \"0.164062500000\"]}, {\"input\": \"+---+--\\r\\n???????\\r\\n\", \"output\": [\"0.1640625000\", \"0.16406250000\", \"0.1640625\", \"0.164062500\", \"0.164062500000\"]}, {\"input\": \"---+-+\\r\\n??????\\r\\n\", \"output\": [\"0.234375000\", \"0.23437500000\", \"0.234375\", \"0.2343750000\", \"0.234375000000\"]}, {\"input\": \"+++-+\\r\\n---++\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"++-+--+\\r\\n?-?+??+\\r\\n\", \"output\": [\"0.375\", \"0.375000000000\", \"0.3750000000\", \"0.375000000\", \"0.37500000000\"]}, {\"input\": \"----+++--\\r\\n-+?+++?--\\r\\n\", \"output\": [\"0.000000000000\", \"0.0000000000\", \"0\", \"0.00000000000\", \"0.0\", \"0.000000000\"]}, {\"input\": \"+-----\\r\\n+?----\\r\\n\", \"output\": [\"0.5\", \"0.50000000000\", \"0.500000000\", \"0.500000000000\", \"0.5000000000\"]}]",
