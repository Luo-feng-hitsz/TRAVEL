  "target_code": "use std::io;\n\nfn get_line() -> String {\n\tlet mut input = String::new();\n\n\tio::stdin().read_line(&mut input)\n\t\t.expect(\"\");\n\n\tString::from(input.trim())\n}\n\nfn main() {\n\tlet s = get_line();\n\n\tlet mut r = String::new();\n\tfor (i, c) in s.chars().enumerate() {\n\t\tlet d = c.to_digit(10).unwrap();\n\n\t\tif (i == 0 && d >= 5 && d < 9) || (i != 0 && d >= 5) {\n\t\t\tr.push(std::char::from_digit((9-d) as u32, 10).unwrap());\n\t\t} else {\n\t\t\tr.push(c);\n\t\t}\n\t}\n\n\tprintln!(\"{}\", r);\n}"
