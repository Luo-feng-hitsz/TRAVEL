  "target_code": "use std::io;\n#[allow(dead_code)]\nfn read() -> String\n{\n    let mut res = String::new();\n    io::stdin().read_line(&mut res).unwrap();\n    res\n}\n#[allow(unused_macros)]\nmacro_rules! read \n{\n    () => \n    {\n        read().trim().parse().unwrap();       \n    };\n}\n#[allow(dead_code)]\nfn read_vec() -> Vec<i64>\n{\n    read().split_whitespace().map(|x| x.parse::<i64>().unwrap()).collect()\n}\nfn main()\n{\n    let n : i32 = read!();\n    println!(\"{}\", (2 + (n - 2) * 2) * (n - 1) + 1 + (n - 1) * 2);\n}"
