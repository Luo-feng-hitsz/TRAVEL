  "source_code": "#include<stdio.h>\n#include<string.h>\nint main()\n{\n    int count=0,t=0,n,m,i;\n    char a[10000];\n    scanf(\"%s\",a);\n    m=strlen(a);\n    for(i=0;i<m&&m!=1;i++)\n    {\n        if(a[i]<=92)\n            count++;\n    }\n        for(i=1;i<m;i++)\n    {\n        if(a[0]>92)\n        {\n            if(a[i]<=92)\n                t++;\n        }\n    }\n\n    if(m==1)\n    {\n        if(a[0]<=92)\n            a[0]=a[0]+32;\n        else\n            a[0]=a[0]-32;\n    }\n\n    else if(count==m)\n    {\n        for(i=0;i<m;i++)\n        {a[i]+=32;}\n    }\n    else  if(t==m-1)\n    {\n        a[0]=a[0]-32;\n        for(i=1;i<m;i++)\n        {\n            a[i]=a[i]+32;\n        }\n    }\n\n    for(i=0;i<m;i++)\n    {\n        printf(\"%c\",a[i]);\n    }\n\n}\n",
