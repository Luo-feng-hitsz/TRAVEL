  "target_code": "use std::io;\n\nfn main() {\n    const vowels: [char; 6] = ['a', 'o', 'y', 'e', 'u', 'i'];\n    \n    let mut input = String::new();\n    io::stdin().read_line(&mut input);\n\n    for letter in input.trim().to_ascii_lowercase().chars() {\n        if vowels.contains(&letter) { continue; }\n        print!(\".\");\n        print!(\"{}\", letter);\n    }\n}\n"
