  "source_code": "#include<stdio.h>\n#include<string.h>\nint main(){\n    char str[101];\n    scanf(\"%s\",&str);\n    int n=strlen(str);\n    for(int i=0;i<n;i++){\n        if(str[i]>=65&&str[i]<=90){\n            str[i]=str[i]+32;\n        }\n    }\n    for(int i=0;i<n;i++){\n        if(str[i]!='a'&&str[i]!='o'&&str[i]!='e'&&str[i]!='i'&&str[i]!='u'&&str[i]!='y'){\n            printf(\".\");\n            printf(\"%c\",str[i]);\n        }\n    }\n        return 0;\n}",
