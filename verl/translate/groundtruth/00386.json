  "prob_desc_output_spec": "Output a single integer representing fn modulo 1000000007 (109 + 7).",
  "source_code": "#include<stdio.h>\n#include<string.h>\n\nint main()\n{\n    int x, y, k;\n    int a[20];\n    scanf(\"%d%d\", &x, &y);\n    a[1]=x;\n    a[2]=y;\n    scanf(\"%d\", &k);\n    for(int i=3; i<=6; i++)\n    {\n        a[i]=a[i-1]-a[i-2];\n    }\n    a[0]=a[6];\n    printf(\"%d\\n\", (((a[k%6]%1000000007)+1000000007)%1000000007));\n    return 0;\n}\n",
