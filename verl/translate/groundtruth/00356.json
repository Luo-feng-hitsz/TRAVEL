  "target_code": "use std::io;\nuse std::str::FromStr;\n\nuse std::cmp::{max, min};\n\nfn get_line() -> String {\n    let mut input = String::new();\n    io::stdin().read_line(&mut input).unwrap();\n    input\n}\n\nfn get_vec<T>(s: String) -> Vec<T>\n    where T: FromStr,\n          <T as FromStr>::Err: std::fmt::Debug,\n{\n    s.split_whitespace().map(|k| k.parse().unwrap()).collect()\n}\n\nfn main() {\n    let (l, r, x, y, k) = {\n        let input = get_line();\n        let mut it = input.split_whitespace().map(|k| k.parse::<u64>().unwrap());\n        (\n            it.next().unwrap(),\n            it.next().unwrap(),\n            it.next().unwrap(),\n            it.next().unwrap(),\n            it.next().unwrap(),\n            )\n    };\n\n    let l2 = k * x;\n    let r2 = k * y;\n\n    let l = max(l, l2);\n    let r = min(r, r2);\n\n    let q = l / k;\n    \n    let ans = r < l || (k * q < l && r < k * (q + 1));\n    let ans = !ans;\n\n    if ans {\n        println!(\"YES\");\n    } else {\n        println!(\"NO\");\n    }\n}\n"
