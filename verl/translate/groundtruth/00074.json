  "target_code": "fn main() {\n    let keyb = \"qwertyuiopasdfghjkl;zxcvbnm,./\";\n    let mut r = String::new();\n    let mut inp = String::new();\n    std::io::stdin()\n        .read_line(&mut r)\n        .expect(\"failed reading from stdin\");\n    std::io::stdin()\n        .read_line(&mut inp)\n        .expect(\"failed reading from stdin\");\n    let keys = inp.trim().chars();\n    for i in keys {\n        if r.trim() == \"R\" {\n            let idx = keyb.find(i).unwrap() - 1;\n            print!(\"{}\", keyb.chars().nth(idx).unwrap())\n        } else {\n            let idx = keyb.find(i).unwrap() + 1;\n            print!(\"{}\", keyb.chars().nth(idx).unwrap())\n        }\n    }\n}\n"
