  "target_code": "use std::io;\n\nfn main() {\n    let mut buf = String::new();\n    io::stdin().read_line(&mut buf).unwrap();\n    let s = buf.trim().parse::<i64>().unwrap();\n    let r = match s {\n        s if s % 2 == 0 => s - s / 2,\n        _ => -(s / 2 + 1),\n    };\n\n    println!(\"{}\", r);\n}\n"
