  "target_code": "use std::io;\n\nfn main() {\n    let mut input = String::new();\n    io::stdin().read_line(&mut input).expect(\"failed to read input\");\n    let mut input_iter = input.split_whitespace();\n    let a = input_iter.next().unwrap();\n    let b = input_iter.next().unwrap();\n    if a == b {\n        println!(\"{}\", a);\n    } else {\n        println!(\"1\");\n    }\n}"
