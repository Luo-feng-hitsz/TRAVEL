  "source_code": "#include<stdio.h>\n\n\nint main()\n{\n    long long int N,M,k,i,j,s,r,d,m,n;\n    long long int B[]= {9,189,2889,38889,488889,5888889,68888889,788888889,8888888889,98888888889,1000000000000};\n    long long int C[]= {9,99,999,9999,99999,999999,9999999,99999999,999999999,9999999999,99999999999,999999999999};\n\n    scanf(\"%lld\", &N);\n\n    if(N<=B[0])\n    {\n        i=0;\n    }\n    else if(N<=B[1])\n    {\n        i=1;\n    }\n    else if(N<=B[2])\n    {\n        i=2;\n    }\n    else if(N<=B[3])\n    {\n        i=3;\n    }\n    else if(N<=B[4])\n    {\n        i=4;\n    }\n    else if(N<=B[5])\n    {\n        i=5;\n    }\n    else if(N<=B[6])\n    {\n        i=6;\n    }\n    else if(N<=B[7])\n    {\n        i=7;\n    }\n    else if(N<=B[8])\n    {\n        i=8;\n    }\n    else if(N<=B[9])\n    {\n        i=9;\n    }\n    else if(N<=B[10])\n    {\n        i=10;\n    }\n\n    if(N<=9)\n    {\n        s=N;\n    }\n    else\n    {\n        r=N-B[i-1];\n        m=r/(i+1);\n        n=r%(i+1);\n        if((r%(i+1))!=0)\n        {\n            m=m+1;\n        }\n        m=m+C[i-1];\n\n        long long int A[i+1];\n\n        for(j=i; j>=0; j--)\n        {\n            A[j]=m%10;\n            m=m/10;\n        }\n\n        if(n==0)\n        {\n            s=A[i];\n        }\n        else\n        {\n            s=A[n-1];\n        }\n    }\n\n    printf(\"%lld\\n\",s);\n\n    return 0;\n}\n",
