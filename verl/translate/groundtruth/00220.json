  "prob_desc_output_spec": "Print \"YES\" if the links and pearls can be rejoined such that the number of links between adjacent pearls is equal. Otherwise print \"NO\". You can print each letter in any case (upper or lower).",
  "source_code": "#include<stdio.h>\n#include<string.h>\nint main()\n{\n    int a,b,i,n;\n    char s[1000];\n    scanf(\"%s\",s);\n    n=strlen(s);\n    a=b=0;\n    for(i=0;i<n;i++)\n    {\n        if(s[i]=='o')\n            b++;\n        else\n            a++;\n    }\n    if(b!=0 && a%b!=0)\n        printf(\"NO\\n\");\n    else\n        printf(\"YES\\n\");\n    return 0;\n}\n",
