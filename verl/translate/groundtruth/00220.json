  "target_code": "fn main() {\n    use std::io::prelude::*;\n    use std::io;\n\n    let mut input = String::new();\n    io::stdin().read_to_string(&mut input).unwrap();\n\n    let necklace: Vec<_> = input.trim().chars().map(|c| {\n        match c {\n            '-' => Elem::Link,\n            'o' => Elem::Pearl,\n            _ => panic!(\"Invalid input\"),\n        }\n    }).collect();\n\n    let link_pearl_sums = necklace.iter().fold((0, 0), |acc, &e| {\n        match e {\n            Elem::Link => (acc.0 + 1, acc.1),\n            Elem::Pearl => (acc.0, acc.1 + 1),\n        }\n    });\n\n    let ans = link_pearl_sums.1 == 0 || link_pearl_sums.0 % link_pearl_sums.1 == 0;\n\n    if ans {\n        println!(\"YES\");\n    } else {\n        println!(\"NO\");\n    }\n}\n\n#[derive(Clone, Copy)]\nenum Elem {\n    Link,\n    Pearl\n}\n"
