  "source_code": "#include<stdio.h>\n#include<stdlib.h>\n#include<string.h>\n#include<math.h>\nint compare (const void * a, const void * b)\n{\n  return ( *(int*)a - *(int*)b );\n}\nint main()\n{\n    int a=0,b=0,n,i,t,val1=0,val2=0,ch=0;\n    scanf(\"%d\",&n);\n    for(i=0;i<n;i++)\n    {\n        scanf(\"%d\",&t);\n        if(t==100)\n        a=a+1;\n        else\n        b=b+1;\n    }\n    val1=b/2;\n    val2=b-val1;\n    if(val1==val2)\n    {\n        if(a%2==0)\n        printf(\"YES\");\n        else\n        printf(\"NO\");\n    }\n    else\n    {\n        if((a>=2)&&(a%2==0))\n        printf(\"YES\");\n        else\n        printf(\"NO\");\n    }\n    return 0;\n}",
