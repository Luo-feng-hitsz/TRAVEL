  "target_code": "fn find_min(m: usize, s: usize) -> String {\n    let mut num = vec![0; m];\n    num[0] = 1;\n    let mut i = m - 1;\n    let mut sum = 1;\n\n    while sum + 9 < s {\n        num[i] = 9;\n        i -= 1;\n        sum += 9;\n    }\n\n    num[i] += (s - sum) as u8;\n    vec_to_num(&num)\n}\n\nfn find_max(m: usize, s: usize) -> String {\n    let mut num = vec![9; m];\n    let mut i = m - 1;\n    let mut sum = 9 * m;\n\n    while sum - 9 > s {\n        num[i] = 0;\n        i -= 1;\n        sum -= 9;\n    }\n\n    num[i] -= (sum - s) as u8;\n    vec_to_num(&num)\n}\n\nfn vec_to_num(v: &Vec<u8>) -> String {\n    v.into_iter()\n        .map(|digit| (digit + 48) as char)\n        .collect::<String>()\n}\n\nfn main() {\n    let (m, s) = {\n        let mut buf = String::new();\n        std::io::stdin().read_line(&mut buf).unwrap();\n        let temp: Vec<usize> = buf\n            .trim()\n            .split_whitespace()\n            .map(|elem| elem.parse().unwrap())\n            .collect();\n        (temp[0], temp[1])\n    };\n\n    if m == 1 && s == 0 {\n        println!(\"0 0\");\n    } else if s < 1 || s > 9 * m {\n        println!(\"-1 -1\");\n    } else {\n        println!(\"{} {}\", find_min(m, s), find_max(m, s))\n    }\n}"
