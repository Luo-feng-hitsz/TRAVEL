  "target_code": "use std::io::*;\n\nfn read<T: std::str::FromStr>(i: &mut StdinLock) -> T {\n    let mut s = String::new();\n    i.by_ref().read_line(&mut s).ok();\n    s.trim().parse().ok().unwrap()\n}\n\nfn main() {\n    // initialize stdin\n    let sin = std::io::stdin();\n    let mut sin = sin.lock();\n    let sin = &mut sin;\n\n    let positions: String = read(sin);\n\n    if positions.contains(\"01111111\")\n        || positions.contains(\"11111110\")\n        || positions.contains(\"10000000\")\n        || positions.contains(\"00000001\")\n    {\n        println!(\"YES\");\n    } else {\n        println!(\"NO\");\n    }\n}\n"
