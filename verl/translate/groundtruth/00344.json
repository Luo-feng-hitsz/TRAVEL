  "source_code": "#include<stdio.h>\n\nint main(){\n\tint dim;\n\tscanf(\"%d\",&dim);\n\tint v[dim];\n\n\tint i;\n\tfor (int i = 0; i <dim; ++i)\n\t{\n\t\tscanf(\"%d\",&v[i]);\n\t}\n\n\tif(dim%2==0){\n\t\tputs(\"No\");\n\t}else{\n\t\tif(v[0]%2==0 || v[dim-1]%2==0){\n\t\t\tputs(\"No\");\n\t\t}else{\n\t\t\tputs(\"Yes\");\n\t\t\t\n\t\t}\n\t}\n\n\treturn 0;\n}",
