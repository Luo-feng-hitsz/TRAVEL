  "target_code": "use std::io;\nuse std::str::FromStr;\nuse std::collections::HashMap;\n\nfn get_num() -> usize{\n    let mut input = String::new();\n\n    io::stdin().read_line(&mut input)\n        .expect(\"\");\n\n    usize::from_str(input.trim()).unwrap()\n}\n\nfn main() {\n    let n = get_num();\n\n    let mut m = HashMap::new();\n    m.insert(0, (0, 0));\n    m.insert(1, (0, 1));\n    m.insert(2, (0, 2));\n    m.insert(3, (0, 2));\n    m.insert(4, (0, 2));\n    m.insert(5, (0, 2));\n    m.insert(6, (1, 2));\n    m.insert(7, (2, 2));\n\n    if n < 8 {\n        let r = m.get(&n).unwrap();\n        println!(\"{} {}\", r.0, r.1);\n    } else {\n        let r = m.get(&(n%7)).unwrap();\n        println!(\"{} {}\", (n/7) * 2 + r.0, (n/7) * 2 + r.1);\n    }\n}\n"
