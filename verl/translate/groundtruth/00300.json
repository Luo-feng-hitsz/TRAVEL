  "target_code": "fn run() {\n    let mut s = String::new();\n    std::io::stdin().read_line(&mut s).unwrap();\n    let mut it = s.trim().split_whitespace();\n    let n: u64 = it.next().unwrap().parse().unwrap();\n    let k: u64 = it.next().unwrap().parse().unwrap();\n    let ans = n / k * k + k;\n    println!(\"{}\", ans);\n}\n\nfn main() {\n    run();\n}"
