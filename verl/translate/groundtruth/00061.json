  "prob_desc_output_spec": "If it is reasonable to build the second oven, print \"YES\". Otherwise print \"NO\".",
  "source_code": "#include <stdio.h>\n#include <stdlib.h>\n\nint main()\n{\n    int n,t,k,d;\n    scanf(\"%d%d%d%d\",&n,&t,&k,&d);\n    int ans=((d/t)+1)*k;\n        if(ans<n)\n            printf(\"YES\");\n        else\n            printf(\"NO\");\n\n    return 0;\n}\n",
