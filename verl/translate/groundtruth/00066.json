  "target_code": "use std::io;\n\nfn main() \n{\n   let mut n =String::new();\n   let mut opt = String::new();\n   io::stdin().read_line(&mut n);\n   io::stdin().read_line(&mut opt);\n\n    let n:usize = n.trim().parse().expect(\"\");\n    let mut ans = 0;\n   for i in 0..n\n   {\n       if opt.chars().nth(i) == Some('-')\n       {\n           ans-=1;\n           if ans<0\n           {\n                ans=0;\n           }\n       }\n       else\n       {\n           ans+=1;\n       }\n   }\n\n   println!(\"{}\", ans);\n}\n"
