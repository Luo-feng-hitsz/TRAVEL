  "target_code": "use std::collections::HashMap;\nuse std::io::stdin;\nfn main() {\n    let mut text = String::new();\n    stdin().read_line(&mut text).unwrap();\n    text.clear();\n    stdin().read_line(&mut text).unwrap();\n    let text = text.trim();\n    let mut counter = 0;\n    for i in spliter(text) {\n        let a = find_distinct_lc(i);\n        if counter < a {\n            counter = a;\n        }\n    }\n    println!(\"{}\", counter);\n}\n\nfn find_distinct_lc(text: &str) -> u8 {\n    let mut hash: HashMap<char, bool> = HashMap::new();\n    let mut counter = 0;\n    for i in text.chars() {\n        match hash.get(&i) {\n            Some(_) => (),\n            _ => {\n                hash.insert(i, true);\n                counter += 1;\n            }\n        }\n    }\n    counter\n}\nfn spliter(text: &str) -> Vec<&str> {\n    text.split(char::is_uppercase).collect()\n}\n"
