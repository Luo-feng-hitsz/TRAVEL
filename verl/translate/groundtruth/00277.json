  "target_code": "use std::io;\n\nfn main() {\n  let mut buffer = String::new();\n  io::stdin().read_line(&mut buffer).unwrap();\n  let input = buffer.split_whitespace()\n                    .map(|x| x.trim().parse::<i64>().unwrap())\n                    .collect::<Vec<i64>>();\n  let n = input[0];\n  let k = input[1];\n  let d = (n / 2) / (k + 1);\n  let c = d * k;\n  let o = n - d - c;\n  println!(\"{} {} {}\", d, c, o);\n}\n"
