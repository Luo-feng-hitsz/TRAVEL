  "prob_desc_output_spec": "First print k — the number of values of n such that the factorial of n ends with m zeroes. Then print these k integers in increasing order.",
  "source_code": "#include<stdio.h>\nint main()\n{\n    int m,num,count,i,mun;\n    scanf(\"%d\",&m);\n    count=0;num=0;\n    while(count<m)\n    {\n        num=num+5;\n        count++;\n        //printf(\"count=%d and num=%d\\n\",count,num);\n        if(num%25==0 && num)\n        {\n            mun=num;\n            while(mun%5==0)\n            {\n                mun/=5;\n                count++;\n            }\n            count--;\n        }\n       // printf(\"count=%d and num=%d\\n\",count,num);\n       \n        \n    }\n    if(count==m)\n    {\n        printf(\"5\\n\");\n        for(i=1 ; i<=5 ; i++ )\n            printf(\"%d \",num++);\n            \n    }\n    else\n        printf(\"0\");\n    return 0;\n}",
