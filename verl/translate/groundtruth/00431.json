  "target_code": "use std::io;\nfn main(){\n    let mut s=String::new();\n    io::stdin().read_line(&mut s).expect(\"Something is wrong\");\n    let n=&s[0..s.find(' ').unwrap()];\n    let mut n:i64=n.trim().parse().unwrap();\n    let k=&s[s.find(' ').unwrap()+1..s.len()];  \n    let mut k:i64=k.trim().parse().unwrap();\n    let mut a:i64=n;\n    let mut p:i64=0;\n    while a%10==0{\n        p+=1;\n        a/=10;\n    }\n    if p>=k{println!(\"{}\",n)}\n    else{k=k-p;\n    match a%10{\n        1|3|7|9=>{for c in 0..k{n*=10}println!(\"{}\",n)},\n        5=>{while a%5==0{p+=1;a/=5;}if k>=p{for c in 0..p{n*=2}for c in 0..k-p{n*=10}}else{for c in 0..k{n*=2}}println!(\"{}\",n);},\n        _=>{while a%2==0{p+=1;a/=2;}if k>=p{for c in 0..p{n*=5}for c in 0..k-p{n*=10}}else{for c in 0..k{n*=5}}println!(\"{}\",n);},\n    }\n}\n}"
