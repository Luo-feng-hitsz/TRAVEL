  "target_code": "use std::io;\nuse std::cmp;\n\nfn solution(input: String) {\n    let max_fits = input.trim().len() / 11;\n    let possible_fits = input.chars().filter_map(|x| {\n        if x == '8' {\n            Some(1)\n        } else {\n            None\n        }\n    }).sum();\n    println!(\"{:?}\", cmp::min(possible_fits, max_fits));\n}\n\npub fn main() {\n    let mut input = String::new();\n    io::stdin().read_line(&mut input);\n    input.clear();\n    match io::stdin().read_line(&mut input) {\n        Ok(n) => {\n            solution(input)\n        }\n        Err(error) => println!(\"error: {}\", error),\n    }\n}\n"
}