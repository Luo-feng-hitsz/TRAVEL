  "source_code": "#include<stdio.h>\n\nint main(){\nint a, b, c, temp, flag;\nscanf(\"%d %d %d\", &a, &b, &c);\n\tif(a==b){\n\t\tprintf(\"YES\");\n\t}\n\t\n\telse if(c==0){\n\t\tif(a==b){\n\t\t\tprintf(\"YES\");\n\t\t}\n\t\telse{\n\t\t\tprintf(\"NO\");\n\t\t}\n\t}\n\t\n\telse if(c==1){\n\t\tif(a<b){\n\t\t\tprintf(\"YES\");\n\t\t}\n\t\telse{\n\t\t\tprintf(\"NO\");\n\t\t}\n\t}\n\t\n\telse if(c==-1){\n\t\tif(a>b){\n\t\t\tprintf(\"YES\");\n\t\t}\n\t\telse{\n\t\t\tprintf(\"NO\");\n\t\t}\n\t}\n\t\n\telse{\n\t\tif(c>0){\n\t\t\tflag=1;\n\t\t}\n\t\telse{\n\t\t\tflag=2;\n\t\t}\n\t\t\n\t\ttemp=a+c;\n\t\twhile(temp!=b){\n\t\t\ttemp=temp+c;\n\t\t\t\tif(flag==1){\n\t\t\t\t\tif(temp>b){\n\t\t\t\t\t\tprintf(\"NO\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t\n\t\t\t\telse if(flag==2){\n\t\t\t\t\tif(temp<b){\n\t\t\t\t\t\tprintf(\"NO\");\n\t\t\t\t\t\tbreak;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t} /*end of while loop*/\n\t\t\n\t\tif(temp==b){\n\t\t\tprintf(\"YES\");\n\t\t}\n\t\n\t}\n\n}\n\n",
