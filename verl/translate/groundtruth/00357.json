  "source_code": "#include <stdio.h>\n#include <stdlib.h>\n#include <ctype.h>\n#include <string.h>\n#include <math.h>\n\nint main()\n{\n    int k,a,b,x,y,m;\n    scanf(\" %d %d %d\",&k,&a,&b);\n\n    if((a<k && b<k) || (a<k && b%k!=0) || (b<k && a%k!=0)){\n        printf(\"-1\\n\");\n    }\n    else{\n        printf(\"%d\\n\",(a/k)+(b/k));\n    }\n\n\n\n    return 0;\n}\n",
