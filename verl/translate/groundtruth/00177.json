  "target_code": "use std::io::stdin;\n\nfn get_in() -> String {\n    let mut input = String::new();\n    stdin().read_line(&mut input).unwrap();\n    input\n}\n\nfn main() {\n    let (n, k) = {\n        let i = get_in();\n        let i: Vec<i64> = i.trim().split(\" \").map(|x| x.parse().unwrap()).collect();\n        (i[0], i[1])\n    };\n    if (n / k) % 2 != 0 {\n        println!(\"YES\");\n    } else {\n        println!(\"NO\");\n    }\n}"
