  "lang": "GNU C11",
  "prob_desc_output_spec": "Output a single integer — the minimum amount of lab works that Vasya has to redo. It can be shown that Vasya can always redo enough lab works to get a $$$5$$$.",
  "source_code": "#include<stdio.h>\nint main(){\n    int n;\n    scanf(\"%d\",&n);\n    int i;\n    int c[6];\n    c[2]=0;\n    c[3]=0;\n    c[4]=0;\n    c[5]=0;\n    for(i=0;i<n;i++){\n        int m;\n        scanf(\"%d\",&m);\n        c[m]++;\n    }\n    int answer=0;\n    int sum;\n    while(1){\n        sum=0;\n        /*\n        for(i=2;i<=5;i++){\n            printf(\" %d:%d\",i,c[i]);\n        }\n        */\n        for(i=2;i<=5;i++){\n            sum+=c[i]*i;\n        }\n        /*\n        printf(\"\\nsum=%d\\n\",sum);\n        printf(\"%d\\n\",4*n+n/2);\n        printf(\"%f\\n\",1.0*sum/n);\n        printf(\"%f\\n\",4.5*n);\n        */\n        //sum>=4.5*n,sum>=4*n+n/2,2*sum>=8*n+n,2*sum>=9*n\n        if(2*sum>=9*n){\n            break;\n        }\n        answer++;\n        for(i=2;i<5;i++){\n            if(c[i]>0){\n                c[i]--;\n                c[5]++;\n                break;\n            }\n        }\n    }\n    printf(\"%d\\n\",answer);\n    return 0;\n}\n",
