  "source_code": "#include <stdio.h>\n\nint main() {\n\tlong long d, ans, k, a, b, t;\n\n\tscanf(\"%lld%lld%lld%lld%lld\", &d, &k, &a, &b, &t);\n\tif (d < k)\n\t\tans = d * a;\n\telse {\n\t\tans = k * a + (d - k) * b;\n\t\tif (ans > (d / k) * (k * a + t) - t + (d % k) * b)\n\t\t\tans = (d / k) * (k * a + t) - t + (d % k) * b;\n\t\tif (ans > (d / k) * (k * a + t) + (d % k) * a)\n\t\t\tans = (d / k) * (k * a + t) + (d % k) * a;\n\t}\n\tprintf(\"%lld\\n\", ans);\n\treturn 0;\n}\n",
