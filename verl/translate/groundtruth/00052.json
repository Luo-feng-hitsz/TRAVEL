  "target_code": "use std::io::stdin;\n\nuse std::collections::HashMap;\n\nfn main() {\n    let k = {\n        let mut input = String::new();\n        stdin().read_line(&mut input).unwrap();\n        let mut it = input.split_whitespace().map(|k| k.parse::<usize>().unwrap());\n        it.next();\n        it.next().unwrap()\n    };\n\n    let mut hm: HashMap<u8, usize> = HashMap::new();\n\n    let mut s = String::new();\n    stdin().read_line(&mut s).unwrap();\n    let s = s.trim();\n    for c in s.as_bytes() {\n        let cnt = hm.entry(*c).or_insert(0);\n        *cnt += 1;\n    }\n\n    let l = hm.values().max().unwrap();\n    if k < *l {\n        println!(\"NO\");\n    } else {\n        println!(\"YES\");\n    }\n}\n"
