  "lang": "GNU C11",
  "prob_desc_output_spec": "Print one integer number — the minimum number of hours required to water the garden.",
  "source_code": "#include <stdio.h>\n\nint main(){\n    int n, k;\n    scanf(\"%d %d\", &n, &k);\n    int a[n];\n    for (int i = 0; i < n; i++){\n        scanf(\"%d\", &a[i]);\n    }\n    int hour = k;\n    for (int i = 0; i  < n; i++){\n        if (k % a[i] == 0 && hour > (k / a[i])){\n            hour = k / a[i];\n        }\n    }\n    printf(\"%d\",hour);\n    return 0;\n}\n",
