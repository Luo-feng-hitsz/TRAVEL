  "target_code": "use std::io::stdin;\n\nfn main() {\n    let mut input = String::new();\n    stdin().read_line(&mut input).unwrap();\n    let nk = input.split_whitespace().map(|x| x.parse::<i32>().unwrap()).collect::<Vec<_>>();\n    let k = &nk[1];\n\n    input.clear();\n    stdin().read_line(&mut input).unwrap();\n    let buckets = input.split_whitespace().map(|x| x.parse::<i32>().unwrap()).collect::<Vec<i32>>();\n\n    let mut best_time = 100;\n    for bucket in buckets {\n        if k % bucket == 0 && k / bucket < best_time {\n            best_time = k / bucket;\n        }\n    }\n    println!(\"{}\", best_time);\n}\n"
