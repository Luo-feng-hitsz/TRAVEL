  "prob_desc_output_spec": "If the golden ticket is lucky then print \"YES\", otherwise print \"NO\" (both case insensitive).",
  "source_code": "#include<stdio.h>\n\nint main()\n{\n    int n;\n    scanf(\"%d\",&n);\n    char s[101];\n    int ar[n],fsum=0,g=0;\n    scanf(\"%s\",s);\n    for(int i=0;i<n;i++)\n    ar[i]=s[i]-'0';\n    for(int i=0;i<n-1;i++)\n    {\n    fsum+=ar[i];\n    int j=i+1,tsum=0,f=0;\n    while(j<n)\n    {\n    tsum+=ar[j++];\n    if(tsum==fsum)\n    {\n    tsum=0;\n    f=2;\n    }\n    else if(tsum>fsum)\n    {\n    f=1;\n    break;\n    }\n    }\n    if(f==2&&j==n&&tsum==0)\n    {\n    g=1;\n    break;\n    }\n    }\n    if(g==1)\n    printf(\"YES\");\n    else\n    printf(\"NO\");\n    return 0;\n}",
