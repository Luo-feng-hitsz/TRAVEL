  "source_code": "#include<stdio.h>\nint main()\n{\n    unsigned long long l1,r1,l2,r2,k,start,end,sum=0;\n    scanf(\"%llu%llu%llu%llu%llu\",&l1,&r1,&l2,&r2,&k);\n    if(l2>r1 || r2<l1)\n        printf(\"0\");\n    else\n    {\n       if(l1>l2)\n            start=l1;\n       else \n            start=l2;\n       if(r2==r1)\n            end =r2;\n       else if(r2>r1)\n            end=r1;\n       else\n            end=r2;\n       sum=sum+end-start+1;\n       if(k>=start && k<=end)\n            sum=sum-1;\n       printf(\"%llu\",sum);\n    }\n}",
