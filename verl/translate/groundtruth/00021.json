  "target_code": "use std::io;\n\nfn main() {\n    let mut s = String::new();\n    for _i in 0..2 {\n        s.clear();\n        io::stdin().read_line(&mut s).unwrap();\n    }\n    s = s.trim().to_string();\n    s = s.to_lowercase();\n    let mut flag = [false; 26];\n    for c in s.chars() {\n        flag[((c as i32) - ('a' as i32)) as usize] = true;\n    }\n    for i in 0..26 {\n        if flag[i as usize] == false {\n            println!(\"NO\");\n            ::std::process::exit(0);\n        }\n    }\n    println!(\"YES\");\n}"
