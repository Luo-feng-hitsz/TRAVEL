  "source_code": "#include<stdio.h>\nint main(void)\n{\n  int i,j,n,m=0,k=0;\n  char a[101];\n  while((scanf(\"%d\",&n))!=EOF)\n  {\n      m=0;\n  for(i=0;i<n;i++)\n  {\n    scanf(\" %c\",&a[i]);\n  }\n for(i='a';i<='z';i++)\n  {\n    for(j=0;j<n;j++)\n    {\n      if(i==a[j]||(i-32)==a[j])\n      {\n        m=1;\n      }\n\n    }\n    if(m==1)\n    {\n\n        k++;\n        m=0;\n    }\n   }\n   if(k==26)\n   {\n     printf(\"YES\\n\");\n   }\n   else\n   {\n     printf(\"NO\\n\");\n   }\n   k=0;\n  }\n   return 0;\n}\n\n                         ",
