: \"500\\r\\\\r\\n\", \"output\": [\"170\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"164\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"176\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"195\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"196\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"196\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"193\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"201\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"201\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"194\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"202\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"204\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"202\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"223\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"217\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"214\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"219\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"217\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"215\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"213\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"216\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"228\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"236\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"238\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"235\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"230\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"233\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"228\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"236\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"1\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"1\"]}, {\"input\": \"500\\r\\\\r\\n\", \"output\": [\"1\"]}]",
