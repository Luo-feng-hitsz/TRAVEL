  "target_code": "use std::io;\n\nfn main() {\n    let mut v = String::new();\n\n    io::stdin().read_line(&mut v).expect(\"read error\");\n\n    let v = v.split_whitespace()\n        .map(|x| x.parse::<u128>().expect(\"parse error\"))\n        .collect::<Vec<u128>>();\n\n    let n = v[0];\n\n    let x = v[1];\n\n    let mut ans: u128 = 0;\n\n    for i in 1..=n {\n        if x % i == 0 && x <= i * n {\n            ans += 1;\n        }\n    }\n\n    println!(\"{}\", ans);\n}\n"
