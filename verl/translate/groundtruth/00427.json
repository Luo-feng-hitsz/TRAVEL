  "target_code": "//jdoodle.com:rustc 1.10.0--codeforces.com:1.19\nfn main(){\n    let mut z=String::new();std::io::stdin().read_line(&mut z);let mut a:i32=z.trim().parse().expect(\"\");a*=2;let mut b=false;\n    for i in 1..(a as f32).sqrt()as i32{\n        let c=a-i*i-i;let d=(c as f32).sqrt()as i32;\n        if d*(d+1)==c{b=true}\n    }\n    print!(\"{}\",if b{\"YES\"}else{\"NO\"})\n}"
