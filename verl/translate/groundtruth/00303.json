  "target_code": "use std::io;\nuse std::iter;\nuse std::cmp;\n\nfn main() {\n    let mut peds = [false; 4];\n    let mut cars = [false; 4];\n\n    for i in 0..4 {\n        let mut input = String::new();\n        io::stdin().read_line(&mut input).unwrap();\n        let it = input.split_whitespace().map(|c| if c == \"0\" {false} else {true});\n        for (j, b) in it.enumerate() {\n            match j {\n                0 => {\n                    cars[i] = b || cars[i];\n                    cars[(i + 3) % 4] = b || cars[(i + 3) % 4];\n                },\n                1 => {\n                    cars[i] = b || cars[i];\n                    cars[(i + 2) % 4] = b || cars[(i + 2) % 4];\n                },\n                2 => {\n                    cars[i] = b || cars[i];\n                    cars[(i + 1) % 4] = b || cars[(i + 1) % 4];\n                },\n                3 => {\n                    peds[i] = b;\n                },\n                _ => (),\n            }\n        }\n    }\n\n    for i in 0..4 {\n        if peds[i] && cars[i] {\n            println!(\"YES\");\n            std::process::exit(0);\n        }\n    }\n\n    println!(\"NO\");\n}\n"
