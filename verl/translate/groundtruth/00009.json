  "target_code": "use std::io;\nuse std::str::FromStr;\n\nconst MAX: usize = 5;\n\nfn get_row() -> (i32, i32, i32) {\n    let mut input = String::new();\n\n    io::stdin().read_line(&mut input)\n        .expect(\"\");\n\n    let v = input.trim()\n                .split_whitespace()\n                .map(|d| i32::from_str(d).unwrap())\n                .collect::<Vec<_>>();\n    (v[0], v[1], v[2])\n}                \n\nfn main() {\n    let mut a = [[0;MAX]; MAX];\n\n    for i in 0..3 {\n        let (x, y, z) = get_row();\n        a[i][0] = x;\n        a[i][1] = y;\n        a[i][2] = z;\n    }\n\n    let x = (a[0][2]+a[2][0] - (a[1][0]+ a[2][0] - (a[0][2]+a[1][2])))/2;\n    let y = x + (a[1][0]+ a[2][0]-(a[0][1]+a[2][1]));\n    let z = x + (a[1][0]+ a[2][0]-(a[0][2]+a[1][2]));\n\n    a[0][0] = x;\n    a[1][1] = y;\n    a[2][2] = z;\n\n    for i in 0..3 {\n        for j in 0..3 {\n            print!(\"{} \", a[i][j]);\n        }\n        println!();\n    }\n}"
