  "source_code": "#include<stdio.h>\n#include<string.h>\nint main()\n{\n    int l1,l2,c=0,j,k;\n    char s1[101],s2[101];\n    scanf(\"%s %s\",s1,s2);\n    l1=strlen(s1);\n    l2=strlen(s2);\n    for(j=0,k=l2-1; j<l1,k>=0; j++,k--) {\n        if(s1[j]==s2[k]) {\n            c++;\n        }\n    }\n    if(l1==c) {\n        printf(\"YES\\n\");\n    }\n    else {\n        printf(\"NO\\n\");\n    }\n}",
