  "target_code": "use std::io;\nuse std::cmp;\n\nfn main() {\n    let mut s = String::new();\n    io::stdin().read_line(&mut s).unwrap();\n    let mut iter = s.trim().split_whitespace().map(|x| x.parse().unwrap());\n    let (n, m, a, b): (u64, u64, u64, u64) = (iter.next().unwrap(), iter.next().unwrap(), iter.next().unwrap(), iter.next().unwrap());\n    let demolition_cost = (n % m) * b;\n    let build_cost = (m - (n % m)) * a;\n    println!(\"{}\", cmp::min(demolition_cost, build_cost));\n}"
