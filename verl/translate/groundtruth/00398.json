  "prob_desc_output_spec": "Print one integer: $$$1$$$ if it is possible to form a regular bracket sequence by choosing the correct order of the given strings, $$$0$$$ otherwise.",
  "source_code": "#include <stdio.h>\n#include <stdlib.h>\n\nint main()\n{\n    int cnt1,cnt2,cnt3,cnt4;\n    scanf(\"%d\",&cnt1);\n    scanf(\"%d\",&cnt2);\n    scanf(\"%d\",&cnt3);\n    scanf(\"%d\",&cnt4);\n    if ((cnt1==cnt4)&&(cnt1>0)){\n        printf(\"%d\",1);\n    }\n    else if ((cnt1==cnt3)&&(cnt3==cnt4)&&(cnt4==0)){\n    printf(\"%d\",1);\n    }\n    else{\n    printf(\"%d\",0);\n    }\n    return 0;\n}",
